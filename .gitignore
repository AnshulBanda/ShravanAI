__pycache__/
*.pyc
.pytest_cache/
*.egg-info/
build/

# Real dataset files -- never committed, only fetched/harmonized locally or on Kaggle
data/raw/*
!data/raw/.gitkeep
data/harmonized/*
!data/harmonized/.gitkeep
data/external/*
!data/external/.gitkeep
data/_quarantine/*
!data/_quarantine/.gitkeep

# Run outputs
results/*
!results/.gitkeep

# wandb local cache
wandb/
